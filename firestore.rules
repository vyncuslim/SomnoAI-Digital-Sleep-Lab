rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required)
    //   - plan: string (required, enum: ['free', 'go', 'pro', 'plus'])
    //   - subscriptionStatus: string (required)
    //   - stripeCustomerId: string (optional)
    //   - stripeSubscriptionId: string (optional)
    //   - currentPeriodEnd: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.email is string &&
             data.plan in ['free', 'go', 'pro', 'plus'] &&
             data.subscriptionStatus is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
