{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "go", "pro", "plus"] },
        "subscriptionStatus": { "type": "string" },
        "stripeCustomerId": { "type": "string" },
        "stripeSubscriptionId": { "type": "string" },
        "currentPeriodEnd": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "plan", "subscriptionStatus"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile and subscription data"
    }
  }
}
