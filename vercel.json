{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=(self)" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https:;" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/.env", "destination": "/404.html" },
    { "source": "/.env.local", "destination": "/404.html" },
    { "source": "/.env.production", "destination": "/404.html" },
    { "source": "/.git/(.*)", "destination": "/404.html" },
    { "source": "/.htaccess", "destination": "/404.html" },
    { "source": "/wp-config.php", "destination": "/404.html" },
    { "source": "/backup.sql", "destination": "/404.html" },
    { "source": "/database.sql", "destination": "/404.html" },
    { "source": "/dump.sql", "destination": "/404.html" },
    { "source": "/config.js", "destination": "/404.html" },
    { "source": "/config.json", "destination": "/404.html" },
    { "source": "/phpinfo.php", "destination": "/404.html" },
    { "source": "/phpmyadmin", "destination": "/404.html" },
    { "source": "/adminer.php", "destination": "/404.html" },
    { "source": "/backup.zip", "destination": "/404.html" },
    { "source": "/admin", "destination": "/404.html" },
    { "source": "/wp-admin", "destination": "/404.html" },
    { "source": "/web.config", "destination": "/404.html" },
    { "source": "/server-status", "destination": "/404.html" },
    { "source": "/server-info", "destination": "/404.html" },
    { "source": "/package.json", "destination": "/404.html" },
    { "source": "/crossdomain.xml", "destination": "/404.html" },
    { "source": "/.DS_Store", "destination": "/404.html" },
    { "source": "/Thumbs.db", "destination": "/404.html" },
    { "source": "/composer.json", "destination": "/404.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
