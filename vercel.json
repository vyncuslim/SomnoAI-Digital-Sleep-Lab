{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|api$|.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|json|xml|txt|html|woff|woff2|ttf|otf|map)).*)",
      "destination": "/index.html"
    }
  ]
}
