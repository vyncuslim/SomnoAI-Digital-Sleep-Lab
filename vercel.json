{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=(self)" }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "/en", "permanent": true },
    { "source": "/.env", "destination": "/404", "permanent": false },
    { "source": "/.git/(.*)", "destination": "/404", "permanent": false },
    { "source": "/wp-config.php", "destination": "/404", "permanent": false },
    { "source": "/package.json", "destination": "/404", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|static/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
